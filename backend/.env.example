# Marketing Agency AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=Marketing Agency AI
DEBUG=true

# Database (SQLite for development, use PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./marketing_agency.db

# OpenAI API Key (required for AI-powered lead qualification & email generation)
OPENAI_API_KEY=your-openai-key-here
LLM_MODEL=gpt-4o-mini

# Redis (for background task queue - optional for development)
REDIS_URL=redis://localhost:6379/0

# Email SMTP (optional - emails will be simulated if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@marketingagency.ai

# Agent Configuration
SCRAPER_INTERVAL_MINUTES=30
MAX_LEADS_PER_BATCH=50
LEAD_SCORE_THRESHOLD=0.6

# Twitter/X API (optional - for social monitoring)
TWITTER_BEARER_TOKEN=

# Google Custom Search (optional - for web lead discovery)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# LinkedIn API (optional)
LINKEDIN_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
